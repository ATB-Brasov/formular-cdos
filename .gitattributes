# Normalize line endings to LF in the repository for all text files.
# On checkout, Windows gets LF too (no CRLF conversion) so the working
# tree always matches the repo and git never shows spurious whitespace diffs.

* text=auto eol=lf

# Explicitly mark common text formats
*.js        text eol=lf
*.ts        text eol=lf
*.svelte    text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.nix       text eol=lf
*.lock      text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
